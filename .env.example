# Copy this file to .env and fill in the values
# Run: node setup.js   to generate ADMIN_PASSWORD_HASH

# Your hashed admin password (generated by setup.js)
ADMIN_PASSWORD_HASH=

# Random secret for session encryption — change this to anything long and random
SESSION_SECRET=change-this-to-a-long-random-string-abc123

# Port (leave as 3000 locally; Railway/Render set this automatically)
PORT=3000
